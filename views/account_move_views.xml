<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Customer Invoice Form: Two Tax Columns Design
        ================================================
        - Keep native tax_ids field visible as "Tax 1" / "Taxes"
        - Add tax2_ids as "Tax 2" column beside it
        - Tax computation override includes both in calculations
    -->
    <record id="view_move_form_inherit_tax2" model="ir.ui.view">
        <field name="name">account.move.form.inherit.tax2</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Invoice Line Tree: Add Tax 2 column after tax_ids -->
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='tax_ids']"
                   position="after">
                <field name="parent_type_tax_use_filter" invisible="1"/>
                <field name="tax2_ids"
                       string="Tax 2"
                       widget="many2many_tags"
                       options="{'no_create': True}"
                       context="{'default_type_tax_use': parent_type_tax_use_filter}"
                       domain="[('type_tax_use','=', parent_type_tax_use_filter), ('company_id','=', company_id)]"/>
            </xpath>

            <!-- Journal Items (line_ids) Tree: Add Tax 2 as optional column -->
            <xpath expr="//field[@name='line_ids']/tree/field[@name='tax_ids']"
                   position="after">
                <field name="parent_type_tax_use_filter" invisible="1"/>
                <field name="tax2_ids"
                       string="Tax 2"
                       widget="many2many_tags"
                       options="{'no_create': True}"
                       optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
