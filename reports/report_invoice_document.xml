<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Invoice PDF: Two Tax Columns
        =============================
        Design:
        - Rename original Taxes column to "Tax 1" and show tax1_ids
        - Add "Tax 2" column after Tax 1 showing tax2_ids
        - Both are native account.tax records handled by Odoo's tax engine

        Note: Odoo 14 invoice report structure uses class-based selectors.
        The Taxes column is the second-to-last header before Price/Amount.
    -->
    <template id="report_invoice_document_inherit_tax2"
              inherit_id="account.report_invoice_document"
              name="Invoice Two Tax Columns">

        <!-- HEADER 1: Rename the Taxes header to "Tax 1" -->
        <!-- Target the th that contains text "Taxes" using class-based selector -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//thead//th[contains(., 'Taxes')]/span[1]"
               position="replace">
            <span>Tax 1</span>
        </xpath>

        <!-- HEADER 2: Add "Tax 2" column after Taxes column -->
        <!-- Target the th containing Taxes text -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//thead//th[contains(., 'Taxes')]"
               position="after">
            <th name="th_tax2" class="text-right">
                <span>Tax 2</span>
            </th>
        </xpath>

        <!-- BODY 1: Modify the original taxes cell to show tax1_ids instead -->
        <!-- Target td in tbody that contains a span with tax_ids reference -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//tbody//td[span[contains(@t-esc, 'tax_ids')]]/span"
               position="replace">
            <t t-if="line.tax1_ids">
                <span t-esc="', '.join([(t.description or t.name) for t in line.tax1_ids])"/>
            </t>
        </xpath>

        <!-- BODY 2: Add Tax 2 cell after Tax 1 cell -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//tbody//td[span[contains(@t-esc, 'tax_ids')]]"
               position="after">
            <td name="account_invoice_line_tax2" class="text-right">
                <t t-if="line.display_type == 'product' or not line.display_type">
                    <t t-if="line.tax2_ids">
                        <span t-esc="', '.join([(t.description or t.name) for t in line.tax2_ids])"/>
                    </t>
                </t>
            </td>
        </xpath>

        <!-- Fix colspan for section/note rows to account for extra column -->
        <xpath expr="//table[contains(@class, 'o_main_table')]//tbody//td[@colspan]"
               position="attributes">
            <attribute name="colspan">99</attribute>
        </xpath>

    </template>

</odoo>
