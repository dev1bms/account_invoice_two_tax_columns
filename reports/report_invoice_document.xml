<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Invoice PDF: Two Tax Columns
        =============================
        Design:
        - Keep original Taxes column as-is (shows tax_ids, which contains both)
        - Add "Tax 2" column after Taxes column to show tax2_ids separately
        - Both are native account.tax records handled by Odoo's tax engine
    -->
    <template id="report_invoice_document_inherit_tax2"
              inherit_id="account.report_invoice_document"
              name="Invoice Two Tax Columns">

        <!-- HEADER: Add "Tax 2" column after Taxes column -->
        <!-- Use the specific th name that exists in Odoo 14 -->
        <xpath expr="//th[@name='th_taxes']" position="after">
            <th name="th_tax2" class="text-right">
                <span>Tax 2</span>
            </th>
        </xpath>

        <!-- BODY: Add Tax 2 cell after Taxes cell -->
        <!-- Use the specific td name that exists in Odoo 14 -->
        <xpath expr="//td[@name='account_invoice_line_taxes']" position="after">
            <td name="account_invoice_line_tax2" class="text-right">
                <t t-if="line.display_type == 'product' or not line.display_type">
                    <t t-if="line.tax2_ids">
                        <span t-esc="', '.join([(t.description or t.name) for t in line.tax2_ids])"/>
                    </t>
                </t>
            </td>
        </xpath>

    </template>

</odoo>
